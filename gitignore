# TypeScript
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ─────────────────────────────────────────────────────────────────────────────
*.local
.cache/
.parcel-cache/
.turbo/

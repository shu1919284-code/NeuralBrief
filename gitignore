# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ─────────────────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────────────────
dist/
server/dist/
build/
out/
.output/

# ─────────────────────────────────────────────────────────────────────────────
# Firebase
# ─────────────────────────────────────────────────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
# .firebaserc is intentionally tracked (contains project aliases, no secrets)

# ─────────────────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.vitest-cache/
*.snap

# ─────────────────────────────────────────────────────────────────────────────
# Editor — VS Code
# ─────────────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
# Optionally track launch.json if your team uses shared debug configs:
# !.vscode/launch.json

# Editor — JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Editor — Vim/Neovim swap files
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# Operating System
# ─────────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


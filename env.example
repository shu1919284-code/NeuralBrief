# =============================================================================
# NeuralBrief — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running the project.
# NEVER commit .env to version control — it is listed in .gitignore.
# Variables prefixed with VITE_ are bundled into the frontend build and are
# safe to expose publicly. All others are server-side only.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Firebase (client-side — safe to expose via VITE_ prefix)
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# ─────────────────────────────────────────────────────────────────────────────

# Your Firebase project's browser API key
VITE_FIREBASE_API_KEY=

# Firebase Auth domain — typically <project-id>.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=

# Your Firebase project ID (used in Firestore, Storage, etc.)
VITE_FIREBASE_PROJECT_ID=

# Firebase Storage bucket — typically <project-id>.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Cloud Messaging sender ID (numeric)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID (unique to this web app registration)
VITE_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Gemini AI (SERVER-SIDE ONLY — never expose to the browser)
# Get from: Google AI Studio (aistudio.google.com) → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Gemini API key used by the Filter Agent and Summary Agent
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Gmail API (SERVER-SIDE ONLY)
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Full setup guide: https://developers.google.com/gmail/api/quickstart
# Required scopes: https://www.googleapis.com/auth/gmail.send
# ─────────────────────────────────────────────────────────────────────────────

# OAuth2 client ID for the Gmail sender account
GMAIL_CLIENT_ID=

# OAuth2 client secret for the Gmail sender account
GMAIL_CLIENT_SECRET=

# Long-lived refresh token obtained after completing the OAuth2 consent flow
GMAIL_REFRESH_TOKEN=

# The Gmail address that sends digest emails to users (e.g. digests@yourdomain.com)
GMAIL_SENDER_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Port the Express server listens on locally (Cloud Run ignores this — uses 8080)
PORT=3001

# Runtime environment: development | production | test
NODE_ENV=development

# A random secret string (min 32 chars) — Cloud Scheduler sends this in the
# X-Cron-Secret header so the /api/cron/digest endpoint rejects unauthorized calls.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK (SERVER-SIDE ONLY)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate Key
# This is a separate credential from the client-side VITE_FIREBASE_* vars above.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase project ID — same value as VITE_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID=

# Service account email address from the downloaded JSON key file
FIREBASE_CLIENT_EMAIL=

# Service account private key — must include the full PEM block with newlines
# Wrap in double quotes: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Production (Google Cloud Run)
# Only required when deploying — leave blank for local development
# ─────────────────────────────────────────────────────────────────────────────

# Fully-qualified Cloud Run service URL (set automatically after first deploy)
# Example: https://neuralbrief-abc123-uc.a.run.app
CLOUD_RUN_URL=
